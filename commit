#!/usr/bin/env bash
set -e

# 📅 Configuration
START_DATE="2026-01-01"
DATE_FILE=".git/.next_commit_date"
MAX_DATE=$(date +%Y-%m-%d) # Date du jour (locale)

# 🔹 Initialisation du fichier de suivi si absent
if [ ! -f "$DATE_FILE" ]; then
    echo "$START_DATE" > "$DATE_FILE"
fi

# 🔹 Lecture de la date courante
CURRENT_DATE=$(cat "$DATE_FILE")

# 🔹 Blocage à la date du jour si dépassement
if [[ "$CURRENT_DATE" > "$MAX_DATE" ]]; then
    CURRENT_DATE="$MAX_DATE"
fi

# 🔹 Injection des dates dans Git (Auteur + Commiteur)
export GIT_AUTHOR_DATE="${CURRENT_DATE}T10:00:00+00:00"
export GIT_COMMITTER_DATE="${CURRENT_DATE}T10:00:00+00:00"

# 🔹 Exécution du commit avec les arguments passés
git commit "$@"

# 🔹 Calcul de la date suivante (GNU date)
NEXT_DATE=$(date -d "$CURRENT_DATE + 1 day" +%Y-%m-%d)

# 🔹 Mise à jour du fichier de suivi (sans dépasser aujourd'hui)
if [[ "$NEXT_DATE" < "$MAX_DATE" || "$NEXT_DATE" == "$MAX_DATE" ]]; then
    echo "$NEXT_DATE" > "$DATE_FILE"
else
    echo "$MAX_DATE" > "$DATE_FILE"
fi